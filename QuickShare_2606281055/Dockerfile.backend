FROM python:3.11-slim

WORKDIR /app

# התקנת תלויות
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    telethon \
    python-dotenv

# העתקת קוד
COPY main.py .

# יצירת תיקיית session
RUN mkdir -p /app/session

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
